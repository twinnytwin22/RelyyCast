# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/bin/
# testing
/coverage
/docs/private/**
# next.js
/.next/
/out/
/mediamtx/win
/mediamtx/mac
/dist/**

/docs/
/cloudflared/win
/cloudflared/mac
# production
/build
/app
/runtime/bun-mp3-helper/dist/

# canonical runtime dependency inventory (track structure + metadata only)
/binaries/**
!/binaries/
!/binaries/README.md
!/binaries/manifest.json
!/binaries/**/.gitkeep

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# code signing certificates (private keys — never commit)
certs/

# typescript
*.tsbuildinfo
next-env.d.ts
