{
  "$schema": "https://neutralino.js.org/schemas/neutralino.config.schema.json",
  "applicationId": "com.relyycast.app",
  "version": "0.1.0",
  "defaultMode": "window",
  "documentRoot": "/app/",
  
  "port": 0,
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "nativeAllowList": [
    "app.*",
    "window.*",
    "events.*",
    "os.*",
    "filesystem.*"
  ],
  "modes": {
    "tray": {
      "icon": "/favicon.ico",
      "menu": [
        {
          "id": "show",
          "text": "Show App"
        },
        {
          "id": "hide",
          "text": "Hide App"
        },
        {
          "id": "exit",
          "text": "Exit"
        }
      ]
    },
    "window": {
      "title": "RelyyCast",
      "icon": "/favicon.ico",
      "width": 1024,
      "height": 500,
      "minWidth": 1024,
      "minHeight": 500,
      "maxWidth": 1024,
      "maxHeight": 500,
      "center": true,
      "borderless": true,
      "resizable": false,
      "maximizable": false,
      "fullScreen": false,
      "maximize": false,
      "useSavedState": false,
      "exitProcessOnClose": false,
      "enableInspector": false,
      "injectGlobals": true,
      "injectClientLibrary": true
    }
  },
  "cli": {
    "binaryName": "relyycast",
    "resourcesPath": "/app/",
    "extensionsPath": "./extensions/",
    "binaryVersion": "6.7.0",
    "frontendLibrary": {
      "patchFile": "/index.html",
      "devUrl": "http://127.0.0.1:3000",
      "projectPath": "/",
      "initCommand": "npm install",
      "devCommand": "npm run dev",
      "buildCommand": "npm run build"
    }
  },
  "logging": {
    "enabled": true,
    "writeToLogFile": false
  }
}
