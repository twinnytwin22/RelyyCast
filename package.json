{
  "name": "relyycast",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000",
    "deps:seed": "node scripts/seed-binaries-from-legacy.mjs",
    "deps:preflight": "node scripts/preflight-runtime-deps.mjs",
    "deps:stage": "node scripts/sync-runtime-assets.mjs",
    "ffmpeg:detect": "node scripts/detect-ffmpeg.mjs",
    "neutralino:run": "npm run deps:preflight && npm run deps:stage && npx neu run",
    "neutralino:build": "npm run deps:preflight && npm run deps:stage && npx neu build && node scripts/stage-dist-binaries.mjs",
    "installer:build": "node scripts/installers/build-installer.mjs",
    "installer:build:skip-sign": "node scripts/installers/build-installer.mjs --skip-sign",
    "release:upload:r2": "node scripts/release/upload-r2.mjs",
    "release:upload:r2:dry-run": "node scripts/release/upload-r2.mjs --dry-run",
    "release:notes": "node scripts/release/generate-patch-notes.mjs",
    "version:bump:decimal": "node scripts/release/bump-version.mjs --mode decimal",
    "version:bump:full": "node scripts/release/bump-version.mjs --mode full",
    "neutralino:update": "npx neu update",
    "build": "npm run deps:preflight && vite build && npm run deps:stage",
    "start": "vite preview --host 127.0.0.1 --port 3000",
    "lint": "eslint ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.911.0",
    "@neutralinojs/lib": "^6.7.0",
    "lucide-react": "^1.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@neutralinojs/neu": "^11.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.1.10"
  }
}
