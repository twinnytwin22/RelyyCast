{
  "name": "relyycast",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000",
    "neutralino:run": "npx neu run",
    "neutralino:build": "npx neu build",
    "neutralino:update": "npx neu update",
    "mp3-helper:dev": "bun run runtime/bun-mp3-helper/src/main.ts",
    "mp3-helper:build": "node scripts/build-bun-mp3-helper.mjs",
    "mp3-helper:build:all": "node scripts/build-bun-mp3-helper.mjs --target bun-windows-x64-modern --target bun-windows-arm64-modern --target bun-darwin-x64 --target bun-darwin-arm64 --target bun-linux-x64-modern --target bun-linux-arm64-modern",
    "build": "vite build && node scripts/sync-runtime-assets.mjs",
    "start": "vite preview --host 127.0.0.1 --port 3000",
    "lint": "eslint ."
  },
  "dependencies": {
    "@neutralinojs/lib": "^6.7.0",
    "lucide-react": "^1.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@neutralinojs/neu": "^11.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.1.10"
  }
}
