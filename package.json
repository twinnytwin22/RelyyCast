{
  "name": "relyycast",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000",
    "neutralino:run": "npx neu run",
    "neutralino:build": "npx neu build",
    "neutralino:update": "npx neu update",
    "dev:neutralino": "npx neu run",
    "app:view": "node scripts/open-app-view.mjs",
    "_dev:app:stack": "concurrently -n WEB,APP -c cyan,green \"npm:dev\" \"npm:app:view\"",
    "dev:app": "node scripts/dev-app.mjs",
    "server:dev": "node server/server.mjs",
    "stack:dev": "concurrently -k -n WEB,SERVER -c cyan,yellow \"npm:neutralino:run\" \"npm:server:dev\"",
    "build": "vite build && node scripts/sync-runtime-assets.mjs",
    "start": "vite preview --host 127.0.0.1 --port 3000",
    "lint": "eslint ."
  },
  "dependencies": {
    "@neutralinojs/lib": "^6.7.0",
    "lucide-react": "^1.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "@neutralinojs/neu": "^11.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.1.10"
  }
}
