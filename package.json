{
  "name": "relyycast",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "next dev",
    "desktop": "electron .",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:forge": "electron-forge start",
    "electron:wait-and-forge": "wait-on tcp:127.0.0.1:3000 && electron-forge start",
    "electron:start": "concurrently -k -n NEXT,ELECTRON -c cyan,magenta \"npm:dev\" \"npm:electron:wait-and-forge\"",
    "electron:package": "electron-forge package",
    "electron:make": "electron-forge make",
    "electron:mac:doctor": "bash scripts/macos-doctor.sh",
    "electron:mac:notary:setup": "bash scripts/macos-notary-setup.sh",
    "electron:mac:package": "RELYY_MAC_SIGN=0 RELYY_MAC_NOTARIZE=0 bash scripts/macos-release.sh package",
    "electron:mac:make": "RELYY_MAC_SIGN=0 RELYY_MAC_NOTARIZE=0 bash scripts/macos-release.sh make",
    "electron:mac:sign": "RELYY_MAC_SIGN=1 RELYY_MAC_NOTARIZE=0 bash scripts/macos-release.sh make",
    "electron:mac:release": "RELYY_MAC_SIGN=1 RELYY_MAC_NOTARIZE=1 bash scripts/macos-release.sh make",
    "electron:mac:installer": "RELYY_MAC_SIGN=0 RELYY_MAC_NOTARIZE=0 bash scripts/macos-build-dmg.sh",
    "electron:mac:installer:sign": "RELYY_MAC_SIGN=1 RELYY_MAC_NOTARIZE=0 bash scripts/macos-build-dmg.sh",
    "electron:mac:installer:release": "RELYY_MAC_SIGN=1 RELYY_MAC_NOTARIZE=1 bash scripts/macos-build-dmg.sh",
    "electron:mac:installer:pkg": "RELYY_MAC_SIGN=0 RELYY_MAC_NOTARIZE=0 bash scripts/macos-build-installer.sh",
    "electron:mac:installer:pkg:sign": "RELYY_MAC_SIGN=1 RELYY_MAC_NOTARIZE=0 bash scripts/macos-build-installer.sh",
    "electron:mac:installer:pkg:release": "RELYY_MAC_SIGN=1 RELYY_MAC_NOTARIZE=1 bash scripts/macos-build-installer.sh"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
